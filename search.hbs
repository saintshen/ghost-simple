{{!< default}}

<header class="gh-header gh-canvas">
    <h1 class="gh-title">Search</h1>
</header>

<style>
.gh-search-wrap { max-width: 600px; margin: 0 auto; padding: 2rem; }
.gh-search-input {
    width: 100%;
    padding: 1rem;
    font-size: 1.6rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    box-sizing: border-box;
}
.gh-search-results { margin-top: 2rem; }
.gh-search-result { padding: 1rem 0; border-bottom: 1px solid #eee; }
.gh-search-result a { color: inherit; text-decoration: none; font-size: 1.4rem; }
.gh-search-result a:hover { text-decoration: underline; }
.gh-search-result p { margin: 0.5rem 0 0; color: #888; font-size: 1.1rem; }
.gh-search-noresults { color: #888; font-size: 1.2rem; padding: 2rem 0; text-align: center; }
</style>

<div class="gh-search-wrap">
    <input type="text" class="gh-search-input" placeholder="Search posts..." autofocus>
    <div class="gh-search-results"></div>
</div>

<script>
(function() {
    var apiKey = window.GHOST_API_KEY;
    var apiUrl = window.GHOST_URL + '/ghost/api/content/posts/?key=' + apiKey + '&limit=20&fields=url,title,excerpt';

    function searchPosts(query) {
        if (!query) {
            document.querySelector('.gh-search-results').innerHTML = '';
            return;
        }
        fetch(apiUrl)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var q = query.toLowerCase();
                var results = data.posts.filter(function(p) {
                    return p.title.toLowerCase().includes(q) ||
                           (p.excerpt && p.excerpt.toLowerCase().includes(q));
                });
                if (results.length === 0) {
                    document.querySelector('.gh-search-results').innerHTML =
                        '<p class="gh-search-noresults">No results for "' + query + '"</p>';
                    return;
                }
                var html = '';
                results.forEach(function(p) {
                    html += '<div class="gh-search-result">' +
                        '<a href="' + p.url + '"><strong>' + p.title + '</strong></a>' +
                        (p.excerpt ? '<p>' + p.excerpt.substring(0, 150) + '...</p>' : '') +
                        '</div>';
                });
                document.querySelector('.gh-search-results').innerHTML = html;
            })
            .catch(function() {
                document.querySelector('.gh-search-results').innerHTML =
                    '<p class="gh-search-noresults">Search unavailable. Please try again later.</p>';
            });
    }

    var input = document.querySelector('.gh-search-input');
    var debounceTimer;
    input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function() {
            searchPosts(input.value.trim());
        }, 300);
    });

    // Auto-focus
    input.focus();
})();
</script>