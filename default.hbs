<!DOCTYPE html>
<html lang="{{@site.locale}}">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="preload" as="style" href="{{asset "built/simple.css"}}">
    <link rel="preload" as="script" href="{{asset "built/simple.js"}}">
    {{> "typography/fonts"}}
    <link rel="stylesheet" type="text/css" href="{{asset "built/simple.css"}}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/brands.min.css" integrity="sha512-DJLNx+VLY4aEiEQFjiawXaiceujj5GA7lIY8CHCIGQCBPfsEG0nGz1edb4Jvw1LR7q031zS5PpPqFuPA8ihlRA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    {{ghost_head}}
<style>
    :where(.nav, .gh-head-menu) .nav-linkedin a,
    :where(.nav, .gh-head-menu) .nav-wechat a,
    :where(.nav, .gh-head-menu) .nav-instagram a {
        font-size: 0 !important;
    }

    :where(.nav, .gh-head-menu) .nav-linkedin a::before,
    :where(.nav, .gh-head-menu) .nav-wechat a::before,
    :where(.nav, .gh-head-menu) .nav-instagram a::before {
        font-family: "Font Awesome 6 Brands";
        display: inline-block;
        font-size: 20px;
        font-style: normal;
        font-weight: normal;
        font-variant: normal;
        text-rendering: auto;
        -webkit-font-smoothing: antialiased;
    }

    :where(.nav, .gh-head-menu) .nav-linkedin a::before {content: "\f08c"}
    :where(.nav, .gh-head-menu) .nav-instagram a::before {content: "\f16d"}
    :where(.nav, .gh-head-menu) .nav-wechat a::before {content: "\f1d7"}

    

    /* Desktop: all menu items in one row */
    .gh-head-menu {
        display: flex;
        align-items: center;
        gap: 0;
    }
    .gh-head-menu .nav {
        display: flex;
        align-items: center;
    }
    .gh-head-menu .nav-search,
    .gh-head-menu .nav-subscribe {
        display: inline-block;
    }
    .gh-head-menu .nav-search a,
    .gh-head-menu .nav-subscribe a,
    .gh-head-menu .nav-search-btn {
        font-size: inherit;
        padding: 0 1.2rem;
        background: none;
        border: none;
        cursor: pointer;
        font: inherit;
        color: inherit;
        text-decoration: none;
    }
    .gh-head-menu .nav-search a::after,
    .gh-head-menu .nav-subscribe a::after {
        display: none;
    }
</style>
</head>

<body class="{{body_class}}">
<div class="gh-viewport">
    <header id="gh-head" class="gh-head">
        <div class="gh-head-brand">
            <a class="gh-head-logo" href="{{@site.url}}">
                {{#if @site.logo}}
                    <img src="{{@site.logo}}" alt="{{@site.title}}" />
                {{else}}
                    {{@site.title}}
                {{/if}}
            </a>
            
        </div>

        <div class="gh-head-menu">
            {{navigation}}
            {{#if @site.members_enabled}}
                {{^if @member}}
                <span class="nav-subscribe"><a href="{{@site.signup_url}}">Subscribe</a></span>
                {{else}}
                <span class="nav-subscribe"><a href="#/portal/account">Account</a></span>
                {{/if}}
            {{/if}}
            <button class="nav-search-btn" id="searchToggle" aria-label="Search">Search</button>
            </div>
        <a class="gh-burger" role="button" aria-label="menu">
            <div class="gh-burger-box">
                <div class="gh-burger-inner"></div>
            </div>
        </a>

    </header>

    <main class="gh-main">
    {{{body}}}
    </main>

    <footer class="gh-foot">
        <div class="gh-container">
            <div class="gh-foot-menu">
                {{navigation type="secondary"}}
            </div>
            <div class="gh-foot-meta">
                Published with <a href="https://ghost.org" target="_blank" rel="noopener">Ghost</a>
            </div>
        </div>
    </footer>

</div>

<script src="{{asset "built/simple.js"}}"></script>
<script>
window.GHOST_API_KEY = '103e0734bdfde4bf80e37fc477';
window.GHOST_URL = '{{@site.url}}';
</script>
<script>
// Custom search toggle — opens Ghost's sodo-search modal if available
document.addEventListener('DOMContentLoaded', function() {
    var searchToggle = document.getElementById('searchToggle');
    if (searchToggle) {
        searchToggle.addEventListener('click', function() {
            // Try Ghost's built-in search (sodo-search)
            var ghostSearch = document.querySelector('[data-ghost-search]');
            if (ghostSearch) {
                ghostSearch.click();
                return;
            }
            // Fallback: trigger keyboard shortcut Ctrl+K / Cmd+K
            var event = new KeyboardEvent('keydown', {
                key: 'k',
                code: 'KeyK',
                keyCode: 75,
                which: 75,
                bubbles: true,
                cancelable: true,
                ctrlKey: true,
                metaKey: false
            });
            document.dispatchEvent(event);
        });
    }
});
</script>
{{ghost_foot}}

{{> "cookie-notice"}}

